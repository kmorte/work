  .rebranding-lp .gdpr-modal-title { margin-bottom: 15px; }
}

@media (max-width: 320px) {
  .gdpr-modal-content { padding: 12px 15px; }
  .gdpr-modal-footer { margin: 10px 0px 0px; }
  .gdpr-modal-setting .gdpr-modal-body p { margin-bottom: 8px; }
  .gdpr-modal-setting .cookies-info { height: 200px; }
}
